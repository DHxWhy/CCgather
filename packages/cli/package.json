{
  "name": "ccgather",
  "version": "2.0.42",
  "description": "CLI tool for syncing Claude Code usage data to CCgather leaderboard",
  "bin": {
    "ccgather": "dist/index.js",
    "ccg": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "claude",
    "anthropic",
    "claude-code",
    "ccgather",
    "leaderboard",
    "cli"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "inquirer": "^9.2.23",
    "open": "^10.1.0",
    "ora": "^8.1.0",
    "string-width": "^7.2.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DHxWhy/CCgather.git"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": "3.1.2",
      "vite": "7.3.2",
      "picomatch": "4.0.4",
      "rollup": "4.60.4",
      "postcss": "8.5.15",
      "ajv": "8.18.0"
    }
  }
}
